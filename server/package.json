    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@routine-app/shared": "*",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2"
  }
}

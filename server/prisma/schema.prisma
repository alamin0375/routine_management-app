// Prisma schema — implements the core data model from
// TECHNICAL_ARCHITECTURE.md §4: users → routines → tasks → completions,
// plus reflections, AI metering, push subscriptions, and refresh tokens.
//
// Load-bearing decisions (see §4 notes):
// - Streaks are computed from Completion, never stored.
// - Every user-owned row cascades on user delete (GDPR delete-my-data).
// - "Day" values are @db.Date in the user's timezone; User.timezone is
//   mandatory and every day-boundary calculation must use it.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PREMIUM
}

enum CompletionSource {
  WEB
  PUSH
  OFFLINE_SYNC
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskSource {
  MANUAL
  AI
  EXTENSION
}

enum TaskInstanceStatus {
  PENDING
  COMPLETED
  SKIPPED
  RESCHEDULED
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String? // null for OAuth-only accounts
  googleId      String?  @unique
  emailVerified Boolean  @default(false)
  timezone      String // IANA name (e.g. "Asia/Dhaka"); mandatory per §4
  plan          Plan     @default(FREE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  routines       Routine[]
  tasks          Task[]
  taskCategories TaskCategory[]
  taskInstances  TaskInstance[]
  completions    Completion[]
  reflections    Reflection[]
  aiInteractions AiInteraction[]
  pushSubs       PushSub[]
  refreshTokens  RefreshToken[]
}

model Routine {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  name       String
  isActive   Boolean   @default(true)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([userId])
}

// Task is a TEMPLATE ("Study React, weekdays, 7-8pm") — never checked off
// directly. TaskInstance rows (one per occurrence date) are what users
// complete. See TASK_SYSTEM_SPEC.md §2.
model Task {
  id                   String         @id @default(uuid()) @db.Uuid
  userId               String         @db.Uuid
  routineId            String?        @db.Uuid // standalone tasks allowed
  title                String
  notes                String?
  categoryId           String?        @db.Uuid
  color                String? // hex; overrides the category color
  priority             Priority       @default(MEDIUM)
  startTime            String? // "HH:mm" wall-clock in the user's timezone (never UTC instants — must survive DST)
  endTime              String? // "HH:mm", same convention
  durationMinutes      Int? // used when start/end times unset
  recurrenceType       RecurrenceType @default(NONE)
  recurrenceDays       Int[] // weekdays 0=Sun..6=Sat (JS Date.getDay() numbering), for WEEKLY
  recurrenceDayOfMonth Int? // 1-31, for MONTHLY; clamps to last day of shorter months
  startDate            DateTime       @db.Date
  endDate              DateTime?      @db.Date // null = forever
  sortOrder            Int            @default(0)
  // Boolean soft-delete per the Task System spec; Routine deliberately keeps
  // its older archivedAt-timestamp convention — the two coexist.
  isArchived           Boolean        @default(false)
  attachments          Json? // reserved for a future phase; no upload endpoints yet
  source               TaskSource     @default(MANUAL)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine     Routine?      @relation(fields: [routineId], references: [id], onDelete: Cascade)
  category    TaskCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  completions Completion[]
  instances   TaskInstance[]

  @@index([userId, isArchived])
  @@index([routineId])
  @@index([userId, startDate])
}

// User-owned grouping (Study, Health, ...) with a display color. Four
// defaults are seeded per user at signup (see DEFAULT_TASK_CATEGORIES).
model TaskCategory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String
  color     String // hex, required
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([userId, name])
  @@index([userId])
}

// One occurrence of a Task on a specific local calendar date — the thing a
// user actually completes. Materialized lazily by GET /tasks/today; the
// (taskId, date) unique makes materialization idempotent under concurrency.
model TaskInstance {
  id                String             @id @default(uuid()) @db.Uuid
  taskId            String             @db.Uuid
  userId            String             @db.Uuid // denormalized for (userId, date) queries
  date              DateTime           @db.Date // local calendar date in the user's timezone
  status            TaskInstanceStatus @default(PENDING) // Phase 4 adds COMPLETED/RESCHEDULED transitions
  overrideStartTime String? // "HH:mm"; per-day override of the template time
  overrideEndTime   String? // "HH:mm"
  overrideNotes     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, date])
  @@index([userId, date])
}

model Completion {
  id          String           @id @default(uuid()) @db.Uuid
  taskId      String           @db.Uuid
  userId      String           @db.Uuid
  date        DateTime         @db.Date // the user-timezone day this completion belongs to
  completedAt DateTime         @default(now())
  source      CompletionSource @default(WEB)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One row per task per day — makes PUT /completions idempotent (§7).
  @@unique([taskId, date])
  @@index([userId, date])
}

model Reflection {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  date      DateTime @db.Date
  mood      Int // 1-5 scale
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model AiInteraction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  kind      String // "suggest-routine" | "refine-routine" | ... (kept open for new features)
  tokensIn  Int
  tokensOut Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PushSub {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  endpoint  String   @unique
  keys      Json // { p256dh, auth } from the PushSubscription
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Rotating refresh tokens, revocable server-side (§5). Only the hash is stored.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

# Copy to .env and adjust. Never commit .env itself.
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/routine_app
# Auth — generate a real secret with: node -e "console.log(crypto.randomBytes(48).toString('hex'))"
JWT_SECRET=dev-only-secret-change-me-0123456789abcdef
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
